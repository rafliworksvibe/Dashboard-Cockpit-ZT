{
  "entities": {
    "Program": {
      "title": "ProgramJob",
      "description": "Program tracker entity containing core details, risk issues, and attachments.",
      "type": "object",
      "properties": {
        "topic": { "type": "string", "description": "Program topic" },
        "subTopic": { "type": "string", "description": "Sub topic" },
        "cluster": { "type": "string", "description": "Strategic cluster" },
        "owner": { "type": "string", "description": "Unit owner" },
        "request": { "type": "string", "description": "Request origin" },
        "ztRole": { "type": "string", "description": "ZT role" },
        "strategicImpact": { "type": "string", "description": "Strategic impact" },
        "phase": { "type": "string", "description": "Program phase" },
        "progress": { "type": "number", "description": "Progress percentage 0-100" },
        "statusTracker": { "type": "string", "description": "Green, Yellow, Red, Blocked" },
        "currentMilestone": { "type": "string", "description": "Milestone status" },
        "keyIssue": { "type": "string", "description": "Key issue or blocker" },
        "actionPlan": { "type": "string", "description": "Action plan or ZT recommendation" },
        "startDate": { "type": "string", "description": "Start date" },
        "deadline": { "type": "string", "description": "Deadline date" },
        "decisionNeeded": { "type": "string", "description": "Yes or No" },
        "dzIntervention": { "type": "string", "description": "Yes or No" },
        "ztPic": { "type": "string", "description": "ZT PIC name" },
        "confidence": { "type": "string", "description": "High, Medium, Low, No-Go" },
        "strategicFit": { "type": "string", "description": "High, Medium, Low" },
        "priority": { "type": "string", "description": "Critical, High, Medium, Low" },
        "riskType": { "type": "string", "description": "Risk category type" },
        "riskIssue": { "type": "string", "description": "Risk description" },
        "riskImpact": { "type": "number", "description": "Impact rating 1-4" },
        "riskProbability": { "type": "number", "description": "Probability rating 1-4" },
        "riskLevelScore": { "type": "number", "description": "Calculated risk score" },
        "riskLevel": { "type": "string", "description": "Risk level label" },
        "riskMitigation": { "type": "string", "description": "Mitigation steps" },
        "clearThePath": { "type": "string", "description": "Path clearing actions" },
        "riskOwner": { "type": "string", "description": "Risk owner" },
        "riskStatus": { "type": "string", "description": "Open, In Progress, Closed" },
        "riskEscalationTo": { "type": "string", "description": "Escalation contact" },
        "justificationConceptor": { "type": "string", "description": "Conceptor name" },
        "documentLink": { "type": "string", "description": "Reference document link" },
        "notes": { "type": "string", "description": "Additional notes" },
        "uid": { "type": "string", "description": "User UID who owns or created this program" }
      },
      "required": ["topic", "cluster", "owner"]
    },
    "MeetingLog": {
      "title": "MeetingLog",
      "description": "Log of meetings or progress updates.",
      "type": "object",
      "properties": {
        "programId": { "type": "string" },
        "programTitle": { "type": "string" },
        "meetingDate": { "type": "string" },
        "notes": { "type": "string" },
        "previousStatus": { "type": "string" },
        "newStatus": { "type": "string" },
        "previousProgress": { "type": "number" },
        "newProgress": { "type": "number" },
        "recordedBy": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["programId", "programTitle", "notes"]
    },
    "UserFolder": {
      "title": "UserFolder",
      "description": "User folder for My Files section.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name"]
    },
    "UserFile": {
      "title": "UserFile",
      "description": "User file metadata for My Files section.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "folderId": { "type": "string" },
        "size": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name"]
    },
    "UserNote": {
      "title": "UserNote",
      "description": "User note for My Notes section.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title"]
    },
    "UserTeamMember": {
      "title": "UserTeamMember",
      "description": "Team member in My Team section.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name"]
    },
    "User": {
      "title": "User",
      "description": "User account document stored in Firestore users collection.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "VIEWER"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User account information containing authorization roles."
    },
    "/programs/{programId}": {
      "schema": { "$ref": "#/entities/Program" },
      "description": "Collection of program tracker records."
    },
    "/logs/{logId}": {
      "schema": { "$ref": "#/entities/MeetingLog" },
      "description": "Collection of meeting logs."
    },
    "/users/{uid}/folders/{folderId}": {
      "schema": { "$ref": "#/entities/UserFolder" },
      "description": "User specific folders."
    },
    "/users/{uid}/files/{fileId}": {
      "schema": { "$ref": "#/entities/UserFile" },
      "description": "User specific files."
    },
    "/users/{uid}/notes/{noteId}": {
      "schema": { "$ref": "#/entities/UserNote" },
      "description": "User specific notes."
    },
    "/users/{uid}/teamMembers/{memberId}": {
      "schema": { "$ref": "#/entities/UserTeamMember" },
      "description": "User specific team members."
    }
  }
}
